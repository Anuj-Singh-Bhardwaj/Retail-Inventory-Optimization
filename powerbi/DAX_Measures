============================================================
PART 1: MEASURES (Used in Visuals & KPIs)
============================================================

--------------------------------------------
1. Base Count & Financial Metrics
--------------------------------------------

// Total SKUs: Count of all products in the dataset
Total SKUs = COUNTROWS('supermarket_inventory_cleaned')

// Total Spoilage Cost: Sum of financial loss from expired products
Total Spoilage Cost = SUM('supermarket_inventory_cleaned'[Spoilage_Cost])

// Total Stockout Cost: Sum of lost profits from zero stockouts (remains 0 in this dataset)
Total Stockout Cost = SUM('supermarket_inventory_cleaned'[Stockout_Cost])

// Total Opportunity Cost: True financial impact (Spoilage + Stockout)
Total Opportunity Cost = SUM('supermarket_inventory_cleaned'[Opportunity_Cost])

--------------------------------------------
2. SKU Counts (Critical & Urgent)
--------------------------------------------

// Critical SKUs: Products with negative Days_Until_Spoilage (already past shelf life)
Critical SKU Count = 
CALCULATE(
    [Total SKUs],
    'supermarket_inventory_cleaned'[Days_Until_Spoilage] < 0
)

// Write Off SKUs: Products that need immediate disposal
Write Off SKU Count = 
CALCULATE(
    [Total SKUs],
    'supermarket_inventory_cleaned'[Spoilage_Urgency] = "CRITICAL: Write Off - Remove from Shelf"
)

// Urgent Action SKUs: Write Off + Deep Discount + Immediate Markdown combined
Urgent Action SKU Count = 
CALCULATE(
    [Total SKUs],
    'supermarket_inventory_cleaned'[Spoilage_Urgency] = "CRITICAL: Write Off - Remove from Shelf" ||
    'supermarket_inventory_cleaned'[Spoilage_Urgency] = "CRITICAL: Deep Discount (70%+) Today" ||
    'supermarket_inventory_cleaned'[Spoilage_Urgency] = "URGENT: Immediate Markdown (50%)"
)

// Safe SKU Count: Products with healthy stock (Days_Until_Spoilage >= 5)
Safe SKU Count = 
CALCULATE(
    [Total SKUs],
    'supermarket_inventory_cleaned'[Spoilage_Urgency] = "Safe"
)

--------------------------------------------
3. Supplier Analysis Measures
--------------------------------------------

// Total Suppliers: Number of distinct suppliers in the dataset
Total Suppliers = 
DISTINCTCOUNT('supermarket_inventory_cleaned'[Supplier])

// Top Offending Supplier: Dynamically shows the supplier with highest spoilage cost
Top Offending Supplier = 
CALCULATE(
    VALUES('supermarket_inventory_cleaned'[Supplier]),
    TOPN(
        1,
        ALL('supermarket_inventory_cleaned'[Supplier]),
        CALCULATE(SUM('supermarket_inventory_cleaned'[Spoilage_Cost]))
    )
)

// Avg Spoilage per Supplier: Average financial loss per supplier
Avg Spoilage per Supplier = 
DIVIDE(
    [Total Spoilage Cost],
    [Total Suppliers]
)

--------------------------------------------
4. Inventory Risk Measures (Used in Context KPIs)
--------------------------------------------

// Stock at Risk: Total dollar value of inventory currently sitting on shelves
Stock at Risk = 
SUMX(
    'supermarket_inventory_cleaned',
    'supermarket_inventory_cleaned'[StockQuantity] * 'supermarket_inventory_cleaned'[Cost_Price]
)

// Write Off Value: Total cost of products flagged for Write Off
Write Off Value = 
CALCULATE(
    [Total Spoilage Cost],
    'supermarket_inventory_cleaned'[Spoilage_Urgency] = "CRITICAL: Write Off - Remove from Shelf"
)

--------------------------------------------
5. Conditional Formatting Measure (For Dashboard Colors)
--------------------------------------------

// Urgency Color: Maps urgency categories to hex codes for background coloring
Urgency Color = 
SWITCH(
    SELECTEDVALUE('supermarket_inventory_cleaned'[Urgency_Short]),
    "Write Off", "#B71C1C",
    "Deep Discount", "#E65100",
    "Markdown", "#F57C00",
    "Discount Today", "#FBC02D",
    "Discount Now", "#FBC02D",
    "Monitor", "#8BC34A",
    "Safe", "#2E7D32",
    "#FFFFFF"
)


